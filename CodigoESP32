//FUNCIÓN MOVIMIENTO DEL MOTOR A RECOGIDA Y DEPÓSITO
void irDeRecogidaADeposito(float x_recogida, float y_recogida, float x_deposito, float y_deposito) 
{
  double t0, t1, t2;
  static bool recogidaAsignada = false;
  static bool recogidaAlcanzada = false;
  static bool depositoAsignado = false;

  const float z = ALTURA_FIJA;
  const double L1 = 230.0;
  const double L2 = 200.0;
  float umbral = 5.0;

  // ESCALAR coordenadas recibidas
  float x1 = x_recogida * escala_global;
  float y1 = y_recogida * escala_global;
  float x2 = x_deposito;
  float y2 = y_deposito;

  // 1. Asignar posición de recogida
  if (!recogidaAsignada) 
  {
    z = 0;
    
    if (cinematicaInversa(x1 * 1000.0, y1 * 1000.0, z, L1, L2, &t0, &t1, &t2)) {
      motorBase.targetDegrees = rad_to_deg(t0);
      motorHombro.targetDegrees = rad_to_deg(t1);
      motorCodo.targetDegrees = rad_to_deg(t2);

      motorBase.targetPulses = (motorBase.targetDegrees / 360.0) * motorBase.pulsesPerTurn;
      motorHombro.targetPulses = (motorHombro.targetDegrees / 360.0) * motorHombro.pulsesPerTurn;
      motorCodo.targetPulses = (motorCodo.targetDegrees / 360.0) * motorCodo.pulsesPerTurn;

      updatePID(motorBase);   driveMotor(motorBase);
      updatePID(motorHombro); driveMotor(motorHombro);
      updatePID(motorCodo);   driveMotor(motorCodo);
      
      recogidaAsignada = true;
    }
  }

  // 2. Control PID para llegar a recogida


  if (recogidaAsignada && !recogidaAlcanzada) 
  {
    bool baseOK   = fabs(motorBase.controlSignal) < umbral;
    bool hombroOK = fabs(motorHombro.controlSignal) < umbral;
    bool codoOK   = fabs(motorCodo.controlSignal) < umbral;

    if (baseOK && hombroOK && codoOK) 
    {
      recogidaAlcanzada = true;
    }
  }

  // 3. Asignar y moverse a posición de depósito
  if (recogidaAlcanzada && !depositoAsignado) {
    
    if (cinematicaInversa(x2 * 1000.0, y2 * 1000.0, z, L1, L2, &t0, &t1, &t2)) {
      motorBase.targetDegrees = rad_to_deg(t0);
      motorHombro.targetDegrees = rad_to_deg(t1);
      motorCodo.targetDegrees = rad_to_deg(t2);

      motorBase.targetPulses = (motorBase.targetDegrees / 360.0) * motorBase.pulsesPerTurn;
      motorHombro.targetPulses = (motorHombro.targetDegrees / 360.0) * motorHombro.pulsesPerTurn;
      motorCodo.targetPulses = (motorCodo.targetDegrees / 360.0) * motorCodo.pulsesPerTurn;

      updatePID(motorBase);   driveMotor(motorBase);
      updatePID(motorHombro); driveMotor(motorHombro);
      updatePID(motorCodo);   driveMotor(motorCodo);
      
      depositoAsignado = true;
    }
    nuevaTarea = false;
  }
}



void moverPalaAGrados(float gradosObjetivo) 
{
  motorBase.targetDegrees = gradosObjetivo;
  motorBase.targetPulses = (motorBase.targetDegrees / 360.0) * motorBase.pulsesPerTurn;

  updatePID(motorBase);   // Calcula nueva señal de control
  driveMotor(motorBase);  // Aplica movimiento al motor
}
